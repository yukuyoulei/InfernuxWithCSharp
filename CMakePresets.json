{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20
  },

  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release Preset (Windows / MSVC)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build",

      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Preset (Windows, RelWithDebInfo + Profiling)",
      "inherits": "release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "release-macos",
      "displayName": "Release Preset (macOS / Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-macos",
      "displayName": "Debug Preset (macOS, RelWithDebInfo + Profiling)",
      "inherits": "release-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "release-macos",
      "configurePreset": "release-macos"
    },
    {
      "name": "debug-macos",
      "configurePreset": "debug-macos"
    },
    {
      "name": "format",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "clang_format"
      ]
    },
    {
      "name": "wiki",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "build_wiki_html"
      ]
    },
    {
      "name": "packaging",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "infernux_hub"
      ]
    },
    {
      "name": "packaging-installer",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "infernux_hub_installer"
      ]
    }
  ]
}
