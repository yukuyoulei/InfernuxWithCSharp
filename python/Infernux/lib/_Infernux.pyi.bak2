class AudioClip:
    """Loaded audio clip data."""

    def __init__(self) -> None: ...
    def load_from_file(self, file_path: str) -> bool: ...
    def unload(self) -> None: ...
    @property
    def is_loaded(self) -> bool: ...
    @property
    def duration(self) -> float: ...
    @property
    def sample_count(self) -> int: ...
    @property
    def sample_rate(self) -> int: ...
    @property
    def channels(self) -> int: ...
    @property
    def file_path(self) -> str: ...
    @property
    def name(self) -> str: ...
    @property
    def guid(self) -> str: ...


class AudioSource(Component):
    """Audio playback component with multi-track support."""

    # Track management
    track_count: int
    def set_track_clip(self, track_index: int, clip: AudioClip) -> None: ...
    def get_track_clip(self, track_index: int) -> Optional[AudioClip]: ...
    def get_track_clip_guid(self, track_index: int) -> str: ...
    def set_track_clip_by_guid(self, track_index: int, guid: str) -> None: ...
    def set_track_volume(self, track_index: int, volume: float) -> None: ...
    def get_track_volume(self, track_index: int) -> float: ...

    # Playback (per-track, default track 0)
    def play(self, track_index: int = 0) -> None: ...
    def stop(self, track_index: int = 0) -> None: ...
    def pause(self, track_index: int = 0) -> None: ...
    def un_pause(self, track_index: int = 0) -> None: ...
    def stop_all(self) -> None: ...

    # One-shot playback
    def play_one_shot(self, clip: AudioClip, volume_scale: float = 1.0) -> None: ...
    def stop_one_shots(self) -> None: ...

    # Track state
    def is_track_playing(self, track_index: int) -> bool: ...
    def is_track_paused(self, track_index: int) -> bool: ...

    # Source-level settings
    volume: float
    pitch: float
    mute: bool
    loop: bool
    play_on_awake: bool
    min_distance: float
    max_distance: float
    one_shot_pool_size: int
    output_bus: str

    @property
    def game_object_id(self) -> int: ...

    def serialize(self) -> str: ...
    def deserialize(self, json_str: str) -> None: ...


class AudioListener(Component):
