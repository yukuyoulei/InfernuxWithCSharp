# Asset Database & Registry
# =============================================================================


class AssetDependencyGraph:
    """Singleton DAG tracking inter-asset dependencies."""

    @staticmethod
    def instance() -> AssetDependencyGraph: ...
    def add_dependency(self, user_guid: str, dependency_guid: str) -> None: ...
    def remove_dependency(self, user_guid: str, dependency_guid: str) -> None: ...
    def clear_dependencies_of(self, user_guid: str) -> None: ...
    def remove_asset(self, guid: str) -> None: ...
    def set_dependencies(self, user_guid: str, dependency_guids: List[str]) -> None: ...
    def get_dependencies(self, guid: str) -> List[str]: ...
    def get_dependents(self, guid: str) -> List[str]: ...
    def has_dependency(self, user_guid: str, dependency_guid: str) -> bool: ...
    def get_edge_count(self) -> int: ...
    def get_node_count(self) -> int: ...
    def clear(self) -> None: ...


class AssetDatabase:
    """Project asset database with GUID-based tracking."""

    def __init__(self) -> None: ...
    def initialize(self, project_root: str) -> None: ...
    def refresh(self) -> None: ...
    def import_asset(self, path: str) -> None: ...
    def delete_asset(self, path: str) -> None: ...
    def move_asset(self, old_path: str, new_path: str) -> None: ...
    def on_asset_created(self, path: str) -> None: ...
    def on_asset_modified(self, path: str) -> None: ...
    def on_asset_deleted(self, path: str) -> None: ...
    def on_asset_moved(self, old_path: str, new_path: str) -> None: ...
    def contains_guid(self, guid: str) -> bool: ...
    def contains_path(self, path: str) -> bool: ...
    def get_guid_from_path(self, path: str) -> str: ...
    def get_path_from_guid(self, guid: str) -> str: ...
    def get_meta_by_guid(self, guid: str) -> ResourceMeta: ...
    def get_meta_by_path(self, path: str) -> ResourceMeta: ...
    def get_all_guids(self) -> List[str]: ...
    def is_asset_path(self, path: str) -> bool: ...
    @property
    def project_root(self) -> str: ...
    @property
    def assets_root(self) -> str: ...

    # Resource management
    def register_resource(self, file_path: str, type: ResourceType) -> str: ...
    def move_resource(self, old_path: str, new_path: str) -> None: ...
    def delete_resource(self, file_path: str) -> None: ...
    def modify_resource(self, file_path: str) -> None: ...
    def get_resource_type(self, file_path: str) -> ResourceType: ...
    def get_all_resource_guids(self) -> List[str]: ...


class AssetRegistry:
    """Singleton asset cache and loader."""

    @staticmethod
    def instance() -> AssetRegistry: ...
    @property
    def is_initialized(self) -> bool: ...
    def get_asset_database(self) -> AssetDatabase: ...
    def load_material_by_path(self, path: str) -> Optional[InxMaterial]: ...
    def load_material_by_guid(self, guid: str) -> Optional[InxMaterial]: ...
    def get_material_by_path(self, path: str) -> Optional[InxMaterial]: ...
    def get_material_by_guid(self, guid: str) -> Optional[InxMaterial]: ...
    def load_mesh_by_path(self, path: str) -> Optional[InxMesh]: ...
    def load_mesh_by_guid(self, guid: str) -> Optional[InxMesh]: ...
    def get_mesh_by_path(self, path: str) -> Optional[InxMesh]: ...
    def get_mesh_by_guid(self, guid: str) -> Optional[InxMesh]: ...
    def get_builtin_material(self, name: str) -> Optional[InxMaterial]: ...
    def load_builtin_material_from_file(self, key: str, mat_file_path: str) -> bool: ...
    def reload_asset(self, guid: str) -> None: ...
    def invalidate_asset(self, guid: str) -> None: ...
    def remove_asset(self, guid: str) -> None: ...
    def on_asset_modified(self, guid: str) -> None: ...
    def on_asset_moved(self, old_guid: str, new_guid: str) -> None: ...
    def on_asset_deleted(self, guid: str) -> None: ...
    def is_loaded(self, guid: str) -> bool: ...


# =============================================================================
# Render Pipeline (SRP)
# =============================================================================


class CullingResults:
    """Result of scene culling."""

    @property
    def visible_object_count(self) -> int: ...
    @property
    def visible_light_count(self) -> int: ...


class ScriptableRenderContext:
    """Render context passed to RenderPipelineCallback.render()."""

    @property
    def scene(self) -> Scene: ...
    def setup_camera_properties(self, camera: Camera) -> None: ...
    def cull(self, camera: Camera) -> CullingResults: ...
    def apply_graph(self, description: RenderGraphDescription) -> None: ...
    def submit_culling(self, culling: CullingResults) -> None: ...
    def execute_command_buffer(self, cmd: CommandBuffer) -> None: ...
    def get_camera_target(self, camera: Camera) -> RenderTargetHandle: ...
    def set_global_texture(self, name: str, handle: RenderTargetHandle) -> None: ...
    def set_global_float(self, name: str, value: float) -> None: ...
    def set_global_vector(self, name: str, x: float, y: float, z: float, w: float) -> None: ...


class RenderPipelineCallback:
    """Abstract base for custom Python render pipelines (override render())."""

    def __init__(self) -> None: ...
    def render(self, context: ScriptableRenderContext, cameras: List[Camera]) -> None: ...
    def dispose(self) -> None: ...


# =============================================================================
# Render Target & CommandBuffer
# =============================================================================


class RenderTargetHandle:
    """Opaque handle to a temporary or persistent render target."""

    @property
    def id(self) -> int: ...
    def is_valid(self) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...


class CommandBuffer:
    """Deferred rendering command buffer."""

    def __init__(self, name: str = "") -> None: ...

    # Render target management
    def get_temporary_rt(
        self,
        width: int,
        height: int,
        format: VkFormat = ...,
        samples: VkSampleCount = ...,
    ) -> RenderTargetHandle: ...
    def release_temporary_rt(self, handle: RenderTargetHandle) -> None: ...
    def set_render_target(self, color: RenderTargetHandle) -> None: ...
    def set_render_target_with_depth(self, color: RenderTargetHandle, depth: RenderTargetHandle) -> None: ...
    def clear_render_target(
        self,
        clear_color: bool,
        clear_depth: bool,
        r: float,
        g: float,
        b: float,
        a: float,
        depth: float = 1.0,
    ) -> None: ...

    # Global shader parameters
    def set_global_texture(self, name: str, handle: RenderTargetHandle) -> None: ...
    def set_global_float(self, name: str, value: float) -> None: ...
    def set_global_vector(self, name: str, x: float, y: float, z: float, w: float) -> None: ...
    def set_global_matrix(self, name: str, data: List[float]) -> None: ...

    # Async readback
    def request_async_readback(self, handle: RenderTargetHandle, callback_id: int) -> None: ...

    # Misc
    def clear(self) -> None: ...
    @property
    def name(self) -> str: ...
    @property
    def command_count(self) -> int: ...


# =============================================================================
# Render Graph
# =============================================================================


class GraphTextureDesc:
    """Description of a texture resource in the Python-defined graph."""

    name: str
    format: int
    is_backbuffer: bool
    is_depth: bool
    width: int
    height: int
    size_divisor: int

    def __init__(self) -> None: ...


class GraphPassDesc:
    """Description of a single render pass in the Python-defined graph."""

    name: str
    read_textures: List[str]
    write_colors: List[Tuple[int, str]]
    write_depth: str
    clear_color: bool
    clear_depth: bool
    clear_color_r: float
    clear_color_g: float
    clear_color_b: float
    clear_color_a: float
    clear_depth_value: float
    action: GraphPassActionType
    queue_min: int
    queue_max: int
    sort_mode: str
    pass_tag: str
    override_material: str
    input_bindings: List[Tuple[str, str]]
    compute_shader_name: str
    dispatch_x: int
    dispatch_y: int
    dispatch_z: int
    light_index: int
    shadow_type: str
    screen_ui_list: int
    shader_name: str
    push_constants: List[Tuple[str, float]]

    def __init__(self) -> None: ...


class RenderGraphDescription:
    """Complete render graph topology defined by Python."""

    name: str
    textures: List[GraphTextureDesc]
    passes: List[GraphPassDesc]
    output_texture: str
    msaa_samples: int

    def __init__(self) -> None: ...


class SceneRenderGraph:
    """The active scene render graph."""

    def mark_dirty(self) -> None: ...
    def apply_python_graph(self, description: RenderGraphDescription) -> None: ...
    def has_python_graph(self) -> bool: ...
    def get_pass_count(self) -> int: ...
    def get_debug_string(self) -> str: ...


