class GameObject:
    """Game object in the scene hierarchy."""

    name: str
    active: bool
    tag: str
    layer: int
    is_static: bool
    prefab_guid: str
    prefab_root: bool

    @property
    def active_self(self) -> bool: ...
    @property
    def active_in_hierarchy(self) -> bool: ...
    @property
    def id(self) -> int: ...
    @property
    def is_prefab_instance(self) -> bool: ...
    @property
    def game_object(self) -> Optional[GameObject]: ...
    @property
    def transform(self) -> Transform: ...
    @property
    def scene(self) -> Scene: ...

    def compare_tag(self, tag: str) -> bool: ...
    def get_transform(self) -> Transform: ...
    def add_component(self, component_type: Any) -> Optional[Any]: ...
    def remove_component(self, component: Any) -> bool: ...
    def can_remove_component(self, component: Any) -> bool: ...
    def get_remove_component_blockers(self, component: Any) -> List[str]: ...
    def get_components(self, component_type: Any = ...) -> List[Any]: ...
    def get_component(self, component_type: Any) -> Optional[Any]: ...
    def get_cpp_component(self, type_name: str) -> Optional[Component]: ...
    def get_cpp_components(self, type_name: str) -> List[Component]: ...
    def add_py_component(self, component_instance: Any) -> Any: ...
    def get_py_component(self, component_type: Any) -> Any: ...
    def get_py_components(self) -> List[Any]: ...
    def remove_py_component(self, component: Any) -> bool: ...

    # Hierarchy
    def get_parent(self) -> Optional[GameObject]: ...
    def set_parent(self, parent: Optional[GameObject], world_position_stays: bool = True) -> None: ...
    def get_children(self) -> List[GameObject]: ...
    def get_child_count(self) -> int: ...
    def get_child(self, index: int) -> GameObject: ...
    def find_child(self, name: str) -> Optional[GameObject]: ...
    def find_descendant(self, name: str) -> Optional[GameObject]: ...
    def is_active_in_hierarchy(self) -> bool: ...

    # Hierarchy component search
    def get_component_in_children(self, component_type: Any, include_inactive: bool = False) -> Any: ...
    def get_component_in_parent(self, component_type: Any, include_inactive: bool = False) -> Any: ...

    # Serialization
    def serialize(self) -> str: ...
    def deserialize(self, json_str: str) -> None: ...

    # Static methods
    @staticmethod
    def find(name: str) -> Optional[GameObject]: ...
    @staticmethod
    def find_with_tag(tag: str) -> Optional[GameObject]: ...
    @staticmethod
    def find_game_objects_with_tag(tag: str) -> List[GameObject]: ...
    @staticmethod
    @overload
    def instantiate(original: Any) -> Optional[GameObject]: ...
    @staticmethod
    @overload
    def instantiate(original: Any, parent: Optional[Any]) -> Optional[GameObject]: ...
    @staticmethod
    @overload
    def instantiate(original: Any, position: Vector3, rotation: quatf) -> Optional[GameObject]: ...
    @staticmethod
    @overload
    def instantiate(original: Any, position: Vector3, rotation: quatf, parent: Optional[Any]) -> Optional[GameObject]: ...
    @staticmethod
    @overload
    def instantiate(original: Any, parent: Optional[Any], instantiate_in_world_space: bool) -> Optional[GameObject]: ...
    @staticmethod
    def instantiate(original: Any, *args: Any, **kwargs: Any) -> Optional[GameObject]: ...
    @staticmethod
    def destroy(game_object: GameObject) -> None: ...


class PendingPyComponent:
    """Pending Python component data for scene restoration."""

    game_object_id: int
    type_name: str
    script_guid: str
    fields_json: str
    enabled: bool


class Scene:
    """A single scene containing GameObjects."""

    name: str

    def set_playing(self, playing: bool) -> None: ...
    def create_game_object(self, name: str = "GameObject") -> GameObject: ...
    def create_primitive(self, type: PrimitiveType, name: str = "") -> GameObject: ...
    def create_primitives_batch(self, type: PrimitiveType, count: int, name_prefix: str = "") -> List[GameObject]: ...
    def create_from_model(self, guid: str, name: str = "") -> Optional[GameObject]: ...
    def get_root_objects(self) -> List[GameObject]: ...
    def get_all_objects(self) -> List[GameObject]: ...
    def find(self, name: str) -> Optional[GameObject]: ...
    def find_by_id(self, id: int) -> Optional[GameObject]: ...
    def find_object_by_id(self, id: int) -> Optional[GameObject]: ...
    def find_with_tag(self, tag: str) -> Optional[GameObject]: ...
    def find_game_objects_with_tag(self, tag: str) -> List[GameObject]: ...
    def find_game_objects_in_layer(self, layer: int) -> List[GameObject]: ...
    def destroy_game_object(self, game_object: GameObject) -> None: ...
    def instantiate_game_object(self, source: GameObject, parent: Optional[GameObject] = None) -> Optional[GameObject]: ...
    def instantiate_from_json(self, json_str: str, parent: Optional[GameObject] = None) -> Optional[GameObject]: ...
    def process_pending_destroys(self) -> None: ...
    def is_playing(self) -> bool: ...
    def start(self) -> None: ...
    def awake_object(self, game_object: GameObject) -> None: ...
    def serialize(self) -> str: ...
    def deserialize(self, json_str: str) -> None: ...
    def save_to_file(self, path: str) -> None: ...
    def load_from_file(self, path: str) -> None: ...
    def has_pending_py_components(self) -> bool: ...
    def take_pending_py_components(self) -> List[PendingPyComponent]: ...

    @property
    def structure_version(self) -> int: ...
    main_camera: Optional[Camera]


class SceneManager:
    """Singleton scene manager."""

    @staticmethod
    def instance() -> SceneManager: ...
    def create_scene(self, name: str) -> Scene: ...
    def get_active_scene(self) -> Optional[Scene]: ...
    def set_active_scene(self, scene: Scene) -> None: ...
    def get_scene(self, name: str) -> Optional[Scene]: ...
    def is_playing(self) -> bool: ...
    def play(self) -> None: ...
    def stop(self) -> None: ...
    def pause(self) -> None: ...
    def is_paused(self) -> bool: ...
    def get_fixed_time_step(self) -> float: ...
    def set_fixed_time_step(self, value: float) -> None: ...
    def get_max_fixed_delta_time(self) -> float: ...
    def set_max_fixed_delta_time(self, value: float) -> None: ...
    def step(self, delta_time: float = 0.016) -> None: ...
    def dont_destroy_on_load(self, game_object: GameObject) -> None: ...
    def mark_mesh_renderers_dirty(self, mesh_guid: str) -> None: ...


# =============================================================================
# Resources
# =============================================================================


class ResourceMeta:
    """Resource metadata attached to every tracked asset."""

    def __init__(self) -> None: ...
    def get_resource_name(self) -> str: ...
    def get_guid(self) -> str: ...
    def get_resource_type(self) -> ResourceType: ...
    def has_key(self, key: str) -> bool: ...
    def get_string(self, key: str) -> str: ...
    def get_int(self, key: str) -> int: ...
    def get_float(self, key: str) -> float: ...


class TextureData:
    """Raw texture data accessible from Python."""

    def __init__(self) -> None: ...
    width: int
    height: int
    channels: int
    name: str
    source_path: str
    def is_valid(self) -> bool: ...
    def get_size_bytes(self) -> int: ...
    def get_pixels(self) -> bytes: ...
    def get_pixels_list(self) -> List[int]: ...


class TextureLoader:
    """Static methods for loading textures."""

    @staticmethod
    def load_from_file(file_path: str, name: str = "") -> TextureData: ...
    @staticmethod
    def load_from_memory(data: bytes, name: str = "") -> TextureData: ...
    @staticmethod
    def create_solid_color(
        width: int, height: int, r: int, g: int, b: int, a: int, name: str = "solid_color"
    ) -> TextureData: ...
    @staticmethod
    def create_checkerboard(
        width: int, height: int, checker_size: int = 8, name: str = "checkerboard"
    ) -> TextureData: ...


class InxMaterial:
    """Material definition with shader properties and render state."""

    def __init__(self) -> None: ...

    @staticmethod
    def __init__(name: str) -> None: ...  # type: ignore[misc]
    @staticmethod
    def __init__(name: str, shader_name: str) -> None: ...  # type: ignore[misc]

    # Properties
    name: str
    @property
    def guid(self) -> str:
        """Material GUID (read-only, set by AssetDatabase)."""
        ...
    file_path: str
    @property
    def material_key(self) -> str:
        """Unique key used by the pipeline manager (GUID > filePath > name)."""
        ...
    is_builtin: bool
    shader_name: str
    vert_shader_name: str
    frag_shader_name: str

    def set_shader(self, shader_name: str) -> None: ...
    def get_render_queue(self) -> int: ...
    def set_render_queue(self, queue: int) -> None: ...
    def save(self) -> None: ...
    def save_to(self, path: str) -> None: ...
    def is_deleted(self) -> bool: ...
    def mark_as_deleted(self) -> None: ...

    # Property setters
    def set_float(self, name: str, value: float) -> None: ...
    def set_vector2(self, name: str, *args: Any) -> None: ...
    def set_vector3(self, name: str, *args: Any) -> None: ...
    def set_vector4(self, name: str, *args: Any) -> None: ...
    def set_color(self, name: str, *args: Any) -> None: ...
    def set_int(self, name: str, value: int) -> None: ...
    def set_matrix(self, name: str, value: Any) -> None: ...
    def set_texture_guid(self, name: str, texture_guid: str) -> None: ...
    def set_param(self, name: str, value: Any) -> None:
        """Set a non-texture material property using value-shape/type dispatch."""
        ...
    def set_texture(self, name: str, value: Any) -> None:
        """Set a texture property from GUID, path, or texture-like object."""
        ...
    def clear_texture(self, name: str) -> None: ...

    # Property getters
    def get_float(self, name: str, default_value: float = 0.0) -> float: ...
    def get_int(self, name: str, default_value: int = 0) -> int: ...
    def get_color(self, name: str) -> vec4f: ...
    def get_vector2(self, name: str) -> Vector2: ...
    def get_vector3(self, name: str) -> Vector3: ...
    def get_vector4(self, name: str) -> vec4f: ...
    def get_texture(self, name: str) -> Optional[str]: ...

    # Generic property access
    def has_property(self, name: str) -> bool: ...
    def get_property(self, name: str) -> Any: ...
    def get_all_properties(self) -> Dict[str, Any]: ...

    # Pipeline state
    def is_pipeline_dirty(self) -> bool: ...
    def clear_pipeline_dirty(self) -> None: ...
    def get_pipeline_hash(self) -> int: ...
    def get_version(self) -> int: ...

    # Serialization
    def serialize(self) -> str: ...
    def deserialize(self, json_str: str) -> None: ...

    # Factory
    @staticmethod
    def create_default_lit() -> InxMaterial: ...
    @staticmethod
    def create_default_unlit() -> InxMaterial: ...

    # Render state
    def get_render_state(self) -> RenderState: ...
    def set_render_state(self, state: RenderState) -> None: ...
    render_state_overrides: int
    def mark_override(self, flag: RenderStateOverride) -> None: ...
    def clear_override(self, flag: RenderStateOverride) -> None: ...
    def has_override(self, flag: RenderStateOverride) -> bool: ...
    def sync_alpha_clip_property(self) -> None: ...


class RenderState:
    """GPU pipeline state for materials."""

    def __init__(self) -> None: ...

    # Rasterization
    cull_mode: int
    front_face: int
    polygon_mode: int
    line_width: float

    # Depth
    depth_test_enable: bool
    depth_write_enable: bool
    depth_compare_op: int

    # Blending
    blend_enable: bool
    src_color_blend_factor: int
    dst_color_blend_factor: int
    color_blend_op: int
    src_alpha_blend_factor: int
    dst_alpha_blend_factor: int
    alpha_blend_op: int

    # Render queue
    render_queue: int

    # Alpha clip
    alpha_clip_enabled: bool
    alpha_clip_threshold: float


