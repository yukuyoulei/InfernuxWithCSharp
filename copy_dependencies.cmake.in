# Auto-generated script to copy DLL dependencies
set(TARGET_DIR "@PYTHON_TARGET_DIR@")
set(BUILD_DIR "@CMAKE_BINARY_DIR@")
set(SOURCE_DIR "@CMAKE_SOURCE_DIR@")
set(MSVC_RUNTIME_DLLS "@CMAKE_INSTALL_SYSTEM_RUNTIME_LIBS@")

# Function to copy file if it exists
function(copy_if_exists src dest)
    if(EXISTS "${src}")
        message(STATUS "Copying ${src} to ${dest}")
        file(COPY "${src}" DESTINATION "${dest}")
    else()
        message(STATUS "File not found: ${src}")
    endif()
endfunction()

# Use the build configuration passed from CMake (Release / RelWithDebInfo / etc.)
# Falls back to Release if not provided.
if(NOT INFERNUX_BUILD_CFG)
    set(_CFG "Release")
else()
    set(_CFG "${INFERNUX_BUILD_CFG}")
endif()

# Determine shared library extension based on platform
if(WIN32)
    set(_SHARED_LIB_EXT "dll")
elseif(APPLE)
    set(_SHARED_LIB_EXT "dylib")
else()
    set(_SHARED_LIB_EXT "so")
endif()

# List of known library directories to search
# On Windows these use per-config subdirectories; on single-config
# generators (Ninja) the libraries sit directly in the directory.
if(WIN32)
    set(LIB_SEARCH_DIRS
        "${BUILD_DIR}/external/${_CFG}"
        "${BUILD_DIR}/external/assimp/bin/${_CFG}"
        "${BUILD_DIR}/external/glslang/glslang/${_CFG}"
        "${BUILD_DIR}/external/glslang/SPIRV/${_CFG}"
        "${BUILD_DIR}/external/SDL/${_CFG}"
        "${BUILD_DIR}/external/JoltPhysics/${_CFG}"
        "${BUILD_DIR}/${_CFG}"
    )
else()
    set(LIB_SEARCH_DIRS
        "${BUILD_DIR}/external"
        "${BUILD_DIR}/external/assimp/bin"
        "${BUILD_DIR}/external/glslang/glslang"
        "${BUILD_DIR}/external/glslang/SPIRV"
        "${BUILD_DIR}/external/SDL"
        "${BUILD_DIR}/external/JoltPhysics"
        "${BUILD_DIR}"
    )
endif()

# Search for shared library files in the build directories
foreach(search_dir ${LIB_SEARCH_DIRS})
    if(EXISTS "${search_dir}")
        file(GLOB lib_files "${search_dir}/*.${_SHARED_LIB_EXT}")
        foreach(lib_file ${lib_files})
            copy_if_exists("${lib_file}" "${TARGET_DIR}")
        endforeach()
    endif()
endforeach()

# Also search for any other shared libs that might be in subdirectories
file(GLOB_RECURSE all_libs "${BUILD_DIR}/*.${_SHARED_LIB_EXT}")
foreach(lib_file ${all_libs})
    get_filename_component(lib_dir ${lib_file} DIRECTORY)
    get_filename_component(lib_name ${lib_file} NAME)

    if(WIN32)
        # Only copy libs from the detected configuration directory
        if(lib_dir MATCHES ".*/${_CFG}$" OR lib_dir MATCHES ".*/${_CFG}/.*")
            copy_if_exists("${lib_file}" "${TARGET_DIR}")
        endif()
    else()
        copy_if_exists("${lib_file}" "${TARGET_DIR}")
    endif()
endforeach()

# Copy the MSVC runtime DLLs discovered by CMake so wheel installs work on clean machines.
if(WIN32)
    foreach(runtime_dll ${MSVC_RUNTIME_DLLS})
        copy_if_exists("${runtime_dll}" "${TARGET_DIR}")
    endforeach()
endif()

message(STATUS "Finished copying shared library dependencies to ${TARGET_DIR}")
